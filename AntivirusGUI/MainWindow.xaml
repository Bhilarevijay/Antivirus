<Window x:Class="AntivirusGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AntivirusGUI.ViewModels"
        xmlns:views="clr-namespace:AntivirusGUI.Views"
        Title="Sentinel Antivirus" Width="1280" Height="820"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimaryBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- DataTemplates: map ViewModel → View -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScanViewModel}">
            <views:ScanView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProtectionViewModel}">
            <views:ProtectionView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsbGuardViewModel}">
            <views:UsbGuardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WebShieldViewModel}">
            <views:WebShieldView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CleanerViewModel}">
            <views:CleanerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TunerViewModel}">
            <views:TunerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QuarantineViewModel}">
            <views:QuarantineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="12" Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="#20FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════ SIDEBAR ═══════ -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarGradientBrush}"
                    CornerRadius="12,0,0,12" BorderBrush="#10FFFFFF" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title Bar (drag area) -->
                    <Border Grid.Row="0" Padding="20,16" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal">
                            <!-- Shield Logo with subtle pulse -->
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource AccentGradientBrush}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#1B9AAA" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="SENTINEL" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="{StaticResource DefaultFont}"/>
                                <TextBlock Text="Security Suite" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Separator -->
                    <Border Grid.Row="1" Height="1" Background="#10FFFFFF" Margin="16,0"/>

                    <!-- Navigation -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,8">
                        <StackPanel>
                            <!-- Main -->
                            <TextBlock Text="MAIN" Style="{StaticResource Caption}" Margin="22,12,0,6"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Dashboard"
                                         Tag="&#xE80F;" IsChecked="True"
                                         Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Scan"
                                         Tag="&#xE8B5;"
                                         Command="{Binding NavigateCommand}" CommandParameter="Scan"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Protection"
                                         Tag="&#xE72E;"
                                         Command="{Binding NavigateCommand}" CommandParameter="Protection"/>

                            <!-- Security -->
                            <TextBlock Text="SECURITY" Style="{StaticResource Caption}" Margin="22,20,0,6"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="USB Guard"
                                         Tag="&#xE88E;"
                                         Command="{Binding NavigateCommand}" CommandParameter="USB Guard"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Web Shield"
                                         Tag="&#xE774;"
                                         Command="{Binding NavigateCommand}" CommandParameter="Web Shield"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Quarantine"
                                         Tag="&#xE7BA;"
                                         Command="{Binding NavigateCommand}" CommandParameter="Quarantine"/>

                            <!-- Tools -->
                            <TextBlock Text="TOOLS" Style="{StaticResource Caption}" Margin="22,20,0,6"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="System Cleaner"
                                         Tag="&#xE74D;"
                                         Command="{Binding NavigateCommand}" CommandParameter="Cleaner"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="System Tuner"
                                         Tag="&#xE713;"
                                         Command="{Binding NavigateCommand}" CommandParameter="Tuner"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Reports"
                                         Tag="&#xE9F9;"
                                         Command="{Binding NavigateCommand}" CommandParameter="Reports"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bottom: Settings only (no window controls here anymore) -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <Border Height="1" Background="#10FFFFFF" Margin="16,0,16,8"/>
                        <RadioButton Style="{StaticResource NavButton}" Content="Settings"
                                     Tag="&#xE115;"
                                     Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════ CONTENT AREA ═══════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar with page title + window controls at top right -->
                <Border Grid.Row="0" Padding="28,12,8,12"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <!-- Page title (left) -->
                        <TextBlock Text="{Binding CurrentPageName}" Style="{StaticResource H1}"
                                   VerticalAlignment="Center"/>

                        <!-- Right side: protection badge + window controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <!-- Protection indicator -->
                            <Border CornerRadius="12" Padding="12,6" Margin="0,0,12,0"
                                    Background="{DynamicResource AccentLightBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="0,0,6,0"/>
                                    <TextBlock Text="Protected" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               FontFamily="{StaticResource DefaultFont}"/>
                                </StackPanel>
                            </Border>

                            <!-- Window Controls — top right like standard Windows -->
                            <Button Content="—" Width="40" Height="32" FontSize="12"
                                    Click="Minimize_Click" Cursor="Hand"
                                    Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0" FontFamily="Segoe UI">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6"
                                                            Padding="0,0,0,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="□" Width="40" Height="32" FontSize="14"
                                    Click="Maximize_Click" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✕" Width="40" Height="32" FontSize="12"
                                    Click="Close_Click" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="#40E74C3C"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content with fade animation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="28,0,28,20">
                    <ContentControl x:Name="PageContainer" Content="{Binding CurrentViewModel}">
                        <ContentControl.RenderTransform>
                            <TranslateTransform x:Name="PageTranslate"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
