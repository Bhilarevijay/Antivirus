<UserControl x:Class="AntivirusGUI.Views.CleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AntivirusGUI.Views">
    <UserControl.Resources>
        <views:FileSizeConverter x:Key="SizeConverter"/>
        <views:NonZeroToVisibilityConverter x:Key="NonZeroVisibility"/>
    </UserControl.Resources>
    <StackPanel>
        <!-- Overview -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="System Cleaner" Style="{StaticResource H2}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource BodyText}">
                        <Run Text="Cleanable data: "/>
                        <Run Text="{Binding TotalCleanable, Converter={StaticResource SizeConverter}}" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBrush}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Analyze" Style="{StaticResource SecondaryButton}" Padding="16,8"
                            Command="{Binding AnalyzeCommand}" Margin="0,0,8,0"/>
                    <Button Content="Clean Now" Style="{StaticResource PrimaryButton}" Padding="16,8"
                            Command="{Binding CleanCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status message -->
        <Border Padding="8,6" Margin="0,0,0,12" CornerRadius="6" Background="{DynamicResource BgHoverBrush}"
                Visibility="{Binding StatusMessage, Converter={StaticResource NonZeroVisibility}}">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource BodyText}" HorizontalAlignment="Center"/>
        </Border>

        <!-- Cleaning Options -->
        <UniformGrid Columns="3">
            <!-- Temp Files -->
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <CheckBox IsChecked="{Binding CleanTemp}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Temp Files" Style="{StaticResource H3}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TempFilesSize, Converter={StaticResource SizeConverter}}"
                               Style="{StaticResource StatValue}" FontSize="24"/>
                    <TextBlock Text="Temporary system files" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Recycle Bin -->
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{DynamicResource DangerBrush}"/>
                        <CheckBox IsChecked="{Binding CleanRecycle}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Recycle Bin" Style="{StaticResource H3}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding RecycleBinSize, Converter={StaticResource SizeConverter}}"
                               Style="{StaticResource StatValue}" FontSize="24"/>
                    <TextBlock Text="Deleted files in recycle bin" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Browser Cache -->
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{DynamicResource InfoBrush}"/>
                        <CheckBox IsChecked="{Binding CleanBrowserCache}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Browser Cache" Style="{StaticResource H3}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding BrowserCacheSize, Converter={StaticResource SizeConverter}}"
                               Style="{StaticResource StatValue}" FontSize="24"/>
                    <TextBlock Text="Cached browser data" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Freed space message -->
        <Border Style="{StaticResource Card}" Margin="0,16,0,0"
                Visibility="{Binding FreedSpace, Converter={StaticResource NonZeroVisibility}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock HorizontalAlignment="Center" Style="{StaticResource H3}" Foreground="{DynamicResource SuccessBrush}">
                    <Run Text="Freed "/>
                    <Run Text="{Binding FreedSpace, Converter={StaticResource SizeConverter}}"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
