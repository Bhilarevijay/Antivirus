<UserControl x:Class="AntivirusGUI.Views.WebShieldView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Master Toggle -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Web Shield" Style="{DynamicResource H2}" Margin="0,0,0,4"/>
                    <TextBlock Text="Block websites (hosts + firewall) and restrict app network access" Style="{DynamicResource BodyText}"/>
                </StackPanel>
                <ToggleButton Style="{DynamicResource ToggleSwitch}" HorizontalAlignment="Right"
                              VerticalAlignment="Center" IsChecked="{Binding WebShieldEnabled}"/>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource Caption}" Margin="0,0,0,12"/>

        <UniformGrid Columns="2" Margin="0,0,0,16">
            <!-- Block Website -->
            <Border Style="{DynamicResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="🌐 Blocked Websites" Style="{DynamicResource H3}" Margin="0,0,0,4"/>
                    <TextBlock Text="Uses hosts file + Windows Firewall + DNS flush" Style="{DynamicResource Caption}" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,12">
                        <TextBox Style="{DynamicResource DarkTextBox}" Text="{Binding NewUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,90,0"/>
                        <Button Content="Block" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Right"
                                Padding="16,8" Command="{Binding AddBlockedSiteCommand}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding BlockedSites}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="6"
                                        Background="{DynamicResource BgHoverBrush}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🚫 " FontSize="12"/>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontFamily="{DynamicResource DefaultFont}" FontSize="13"/>
                                        </StackPanel>
                                        <Button Content="✕" HorizontalAlignment="Right" FontSize="10"
                                                Style="{DynamicResource DangerButton}" Padding="8,4"
                                                Command="{Binding DataContext.RemoveBlockedSiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Block Application Network Access -->
            <Border Style="{DynamicResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="🛡️ Blocked Applications" Style="{DynamicResource H3}" Margin="0,0,0,4"/>
                    <TextBlock Text="Block app network access via Windows Firewall" Style="{DynamicResource Caption}" Margin="0,0,0,12"/>
                    <Button Content="📁 Browse &amp; Block Application..." Style="{DynamicResource PrimaryButton}"
                            Padding="16,8" HorizontalAlignment="Stretch" Margin="0,0,0,12"
                            Command="{Binding AddBlockedAppCommand}"/>
                    <ItemsControl ItemsSource="{Binding BlockedApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="6"
                                        Background="{DynamicResource BgHoverBrush}">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontFamily="{DynamicResource DefaultFont}" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Content="✕" HorizontalAlignment="Right" FontSize="10"
                                                Style="{DynamicResource DangerButton}" Padding="8,4"
                                                Command="{Binding DataContext.RemoveBlockedAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </UniformGrid>
    </StackPanel>
</UserControl>
