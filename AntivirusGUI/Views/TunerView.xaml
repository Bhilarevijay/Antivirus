<UserControl x:Class="AntivirusGUI.Views.TunerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AntivirusGUI.Views">
    <UserControl.Resources>
        <views:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>
    </UserControl.Resources>
    <StackPanel>
        <!-- System Metrics -->
        <UniformGrid Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="CPU Usage" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0:F0}%'}" Style="{StaticResource StatValue}"/>
                    <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="6" Margin="0,8,0,0"
                                 Style="{StaticResource AccentProgressBar}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="RAM Usage" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding RamUsage, StringFormat='{}{0:F0}%'}" Style="{StaticResource StatValue}"/>
                    <ProgressBar Value="{Binding RamUsage}" Maximum="100" Height="6" Margin="0,8,0,0"
                                 Style="{StaticResource AccentProgressBar}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Disk Usage" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding DiskUsage, StringFormat='{}{0:F0}%'}" Style="{StaticResource StatValue}"/>
                    <ProgressBar Value="{Binding DiskUsage}" Maximum="100" Height="6" Margin="0,8,0,0"
                                 Style="{StaticResource AccentProgressBar}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Optimize Button -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="System Optimization" Style="{StaticResource H2}" Margin="0,0,0,4"/>
                    <TextBlock Text="Optimize startup programs and system services" Style="{StaticResource BodyText}"/>
                </StackPanel>
                <Button Content="Optimize Now" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding OptimizeCommand}"/>
            </Grid>
        </Border>

        <!-- Startup Programs -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Startup Programs" Style="{StaticResource H3}" Margin="0,0,0,16"/>
                <ItemsControl ItemsSource="{Binding StartupItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,10" Margin="0,0,0,4" CornerRadius="8"
                                    Background="{DynamicResource BgHoverBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="{StaticResource DefaultFont}" FontSize="13"/>
                                        <TextBlock Text="{Binding Publisher}" Style="{StaticResource Caption}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="4" Padding="8,3" Margin="0,0,12,0"
                                            Background="{DynamicResource BgInputBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Impact}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontFamily="{StaticResource DefaultFont}"/>
                                    </Border>
                                    <ToggleButton Grid.Column="3" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No startup programs detected" Style="{StaticResource BodyText}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"
                           Visibility="{Binding StartupItems.Count, Converter={StaticResource ZeroToVisibility}}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

