<UserControl x:Class="AntivirusGUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AntivirusGUI.Views">
    <UserControl.Resources>
        <views:HealthToWidthConverter x:Key="HealthToWidth"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ PROTECTION STATUS ═══ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Shield Icon with Glow -->
                <Grid Grid.Column="0" Margin="0,0,24,0">
                    <Ellipse Width="80" Height="80" Fill="{DynamicResource AccentLightBrush}"/>
                    <Ellipse Width="64" Height="64">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF1B9AAA" Offset="0"/>
                                <GradientStop Color="#FF2ECC71" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Status Text -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProtectionStatus}" FontSize="26" FontWeight="Bold"
                               FontFamily="{StaticResource DefaultFont}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding ProtectionDescription}"
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{StaticResource DefaultFont}" Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Quick Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Quick Scan" Style="{StaticResource PrimaryButton}"
                            Command="{Binding QuickScanCommand}" Margin="0,0,8,0"/>
                    <Button Content="Update" Style="{StaticResource SecondaryButton}"
                            Command="{Binding UpdateSignaturesCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATS CARDS ═══ -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
            <!-- Files Scanned -->
            <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TotalScanned}" Style="{StaticResource StatValue}"/>
                    <TextBlock Text="Files Scanned" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Threats Blocked -->
            <Border Style="{StaticResource Card}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ThreatsBlocked}" Style="{StaticResource StatValue}"/>
                    <TextBlock Text="Threats Blocked" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Signatures -->
            <Border Style="{StaticResource Card}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SignatureCount}" Style="{StaticResource StatValue}"/>
                    <TextBlock Text="Signatures" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Last Scan -->
            <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="&#xE121;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="{DynamicResource InfoBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding LastScanTime}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{StaticResource DefaultFont}"/>
                    <TextBlock Text="Last Scan" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══ SYSTEM HEALTH + GPU ═══ -->
        <UniformGrid Grid.Row="2" Columns="2">
            <!-- System Health -->
            <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="System Health" Style="{StaticResource H3}" Margin="0,0,0,16"/>
                    <Grid Height="12" Margin="0,0,0,8">
                        <Border CornerRadius="6" Background="#20FFFFFF"/>
                        <Border CornerRadius="6" HorizontalAlignment="Left"
                                Width="{Binding SystemHealth, Converter={StaticResource HealthToWidth}}"
                                Background="{DynamicResource AccentGradientBrush}"/>
                    </Grid>
                    <TextBlock FontSize="14" FontFamily="{StaticResource DefaultFont}"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding SystemHealth, StringFormat='{}{0:F0}%'}"/>
                        <Run Text=" — Your system is in great shape"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- GPU Status -->
            <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="GPU Acceleration" Style="{StaticResource H3}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding GpuStatus}" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource DefaultFont}"/>
                    </StackPanel>
                    <TextBlock Text="CUDA-accelerated SHA-256 hashing active"
                               Style="{StaticResource Caption}"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
