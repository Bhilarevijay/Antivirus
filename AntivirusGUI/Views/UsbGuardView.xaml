<UserControl x:Class="AntivirusGUI.Views.UsbGuardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Master USB Storage Blocking -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="USB Storage Blocking" Style="{DynamicResource H2}" Margin="0,0,0,4"/>
                    <TextBlock Text="Block ALL USB mass storage devices globally (registry-level)" Style="{DynamicResource BodyText}"/>
                </StackPanel>
                <ToggleButton Style="{DynamicResource ToggleSwitch}" HorizontalAlignment="Right"
                              VerticalAlignment="Center" IsChecked="{Binding UsbBlockingEnabled}"/>
            </Grid>
        </Border>

        <!-- Connected Devices -->
        <Border Style="{DynamicResource Card}">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <TextBlock Text="Connected USB Devices" Style="{DynamicResource H3}"/>
                    <Button Content="⟳ Refresh" Style="{DynamicResource SecondaryButton}"
                            HorizontalAlignment="Right" Padding="16,8"
                            Command="{Binding RefreshDevicesCommand}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,12" Margin="0,0,0,8" CornerRadius="8"
                                    Background="{DynamicResource BgHoverBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <TextBlock Text="&#xE88E;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="{DynamicResource DefaultFont}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DeviceId}" Foreground="{DynamicResource TextMutedBrush}"
                                                   FontFamily="{DynamicResource DefaultFont}" FontSize="10"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border Grid.Column="2" CornerRadius="4" Padding="8,3" VerticalAlignment="Center" Margin="8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#332ECC71"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                        <Setter Property="Background" Value="#33E74C3C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="11"
                                                   FontFamily="{DynamicResource DefaultFont}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF2ECC71"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                            <Setter Property="Foreground" Value="#FFE74C3C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Toggle Enable/Disable Button -->
                                    <Button Grid.Column="3" VerticalAlignment="Center" Margin="4,0"
                                            Padding="12,6" FontSize="11"
                                            Command="{Binding DataContext.ToggleDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Content" Value="⛔ Disable"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                        <Setter Property="Content" Value="✅ Enable"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Status message -->
                <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource Caption}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
