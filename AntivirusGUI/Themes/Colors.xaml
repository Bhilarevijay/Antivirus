<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="BgPrimaryColor">#FF0D1B2A</Color>
    <Color x:Key="BgSecondaryColor">#FF1B2838</Color>
    <Color x:Key="BgCardColor">#FF162032</Color>
    <Color x:Key="BgHoverColor">#FF1E3048</Color>
    <Color x:Key="BgInputColor">#FF0F2033</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#FF1B9AAA</Color>
    <Color x:Key="AccentHoverColor">#FF22B8CC</Color>
    <Color x:Key="AccentLightColor">#331B9AAA</Color>

    <!-- Status -->
    <Color x:Key="SuccessColor">#FF2ECC71</Color>
    <Color x:Key="WarningColor">#FFF39C12</Color>
    <Color x:Key="DangerColor">#FFE74C3C</Color>
    <Color x:Key="InfoColor">#FF3498DB</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFECEFF4</Color>
    <Color x:Key="TextSecondaryColor">#FF8899AA</Color>
    <Color x:Key="TextMutedColor">#FF556677</Color>

    <!-- Brushes — use DynamicResource so theme changes propagate -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{DynamicResource BgPrimaryColor}" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{DynamicResource BgSecondaryColor}" />
    <SolidColorBrush x:Key="BgCardBrush" Color="{DynamicResource BgCardColor}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{DynamicResource BgHoverColor}" />
    <SolidColorBrush x:Key="BgInputBrush" Color="{DynamicResource BgInputColor}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{DynamicResource AccentLightColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />

    <!-- Gradients -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1B9AAA" Offset="0"/>
        <GradientStop Color="#FF16C784" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DangerGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFE74C3C" Offset="0"/>
        <GradientStop Color="#FFC0392B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0A1628" Offset="0"/>
        <GradientStop Color="#FF0D1B2A" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
